# =============================================================================
# Capability: Error Handling
# =============================================================================


@pytest.mark.capability("error_handling")
class TestErrorHandling:
    """Test Code Agent's error handling capabilities."""

    @pytest.mark.asyncio
    async def test_handles_tool_failure(self):
        """Test agent handles tool execution failure gracefully."""
        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 1,
                "result": {},
                "error": "File not found",
            })

            result = await agent.run(
                goal="Read nonexistent.py",
                allowed_tools={"Read"},
            )

            assert result["status"] == "failed"
            assert result["error"] is not None

    @pytest.mark.asyncio
    async def test_handles_spawn_exception(self):
        """Test agent handles kernel spawn exception."""
        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.spawn = AsyncMock(side_effect=RuntimeError("Kernel error"))

            result = await agent.run(
                goal="Do something",
                allowed_tools={"Read"},
            )

            assert result["status"] == "failed"
            assert "Kernel error" in result["error"]


# =============================================================================
# Integration: Gemini Adapter
# =============================================================================


@pytest.mark.capability("llm_integration")
class TestGeminiAdapterCapability:
    """Test Gemini adapter's message handling."""

    def test_tool_format_conversion(self):
        """Test OpenAI to Gemini tool format conversion."""
        adapter = GeminiAdapter(MagicMock())

        openai_tools = [
            {
                "type": "function",
                "function": {
                    "name": "Read",
                    "description": "Read file",
                    "parameters": {
                        "type": "object",
                        "properties": {
                            "file_path": {"type": "string"}
                        },
                        "required": ["file_path"]
                    }
                }
            },
            {
                "type": "function",
                "function": {
                    "name": "Glob",
                    "description": "Find files",
                    "parameters": {}
                }
            }
        ]

        gemini_tools = adapter._convert_tools_to_gemini(openai_tools)

        assert len(gemini_tools) == 1
        assert "function_declarations" in gemini_tools[0]
        decls = gemini_tools[0]["function_declarations"]
        assert len(decls) == 2
        assert decls[0]["name"] == "Read"
        assert decls[1]["name"] == "Glob"

    def test_message_conversion_with_tool_results(self):
        """Test message conversion handles tool results."""
        adapter = GeminiAdapter(MagicMock())

        messages = [
            {"role": "system", "content": "You are helpful"},
            {"role": "user", "content": "Find Python files"},
            {"role": "assistant", "content": "I'll search...", "tool_calls": [
                {"id": "1", "type": "function", "function": {"name": "Glob", "arguments": "{}"}}
            ]},
            {"role": "tool", "tool_call_id": "1", "content": "main.py\nutils.py"},
            {"role": "user", "content": "Now read main.py"},
        ]

        prompt, history, sys_inst = adapter._messages_to_prompt_history(messages)

        assert prompt == "Now read main.py"
        assert sys_inst == "You are helpful"
        # History should include user/assistant/tool messages
        assert len(history) >= 2


# =============================================================================
# Convenience Methods
# =============================================================================


@pytest.mark.capability("api_usability")
class TestConvenienceMethods:
    """Test CodeAgent convenience methods."""

    @pytest.mark.asyncio
    async def test_search_code_method(self):
        """Test search_code convenience method."""
        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.run = AsyncMock(return_value={"output": "Found matches"})

            result = await agent.search_code(
                pattern="def test_",
                file_type="py",
                path="tests"
            )

            # Verify run was called with appropriate parameters
            call_kwargs = agent.run.call_args.kwargs
            assert "def test_" in call_kwargs["goal"]
            assert "py" in call_kwargs["goal"]
            assert "tests" in call_kwargs["goal"]
            assert "Grep" in call_kwargs["allowed_tools"]

    @pytest.mark.asyncio
    async def test_read_file_method(self):
        """Test read_file convenience method."""
        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.run = AsyncMock(return_value={"output": "File contents"})

            await agent.read_file("src/main.py")

            call_kwargs = agent.run.call_args.kwargs
            assert "src/main.py" in call_kwargs["goal"]
            assert call_kwargs["allowed_tools"] == {"Read"}


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
