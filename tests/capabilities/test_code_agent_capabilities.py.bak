"""Capability tests for Code Agent Application.

Tests the CodeAgent's core capabilities:
- File search (Glob)
- Content search (Grep)
- File reading (Read)
- Command execution (Bash)
- Multi-tool orchestration

These tests use mocked LLM to verify the agent's behavior without
requiring actual LLM API calls.
"""

import pytest
from pathlib import Path
from typing import List, Dict, Any
from unittest.mock import AsyncMock, MagicMock, patch

from nimbus.apps.code_agent import CodeAgent, GeminiAdapter
from nimbus.llm.base import CompletionResponse, ToolCall


# =============================================================================
# Mock Factory
# =============================================================================


def create_mock_llm_response(
    content: str = None,
    tool_calls: List[Dict[str, Any]] = None,
) -> CompletionResponse:
    """Create a mock CompletionResponse.

    Args:
        content: Text content of response
        tool_calls: List of tool call dicts with 'name' and 'arguments'

    Returns:
        CompletionResponse instance
    """
    tcs = []
    if tool_calls:
        for i, tc in enumerate(tool_calls):
            tcs.append(ToolCall(
                id=f"call_{i}",
                name=tc["name"],
                arguments=tc.get("arguments", {}),
            ))

    return CompletionResponse(
        content=content,
        tool_calls=tcs,
        finish_reason="stop" if not tcs else "tool_calls",
    )


class MockLLMForCodeAgent:
    """Mock LLM that simulates multi-turn tool calling."""

    def __init__(self, responses: List[CompletionResponse]):
        """Initialize with a sequence of responses.

        Args:
            responses: Responses to return in sequence
        """
        self.responses = responses
        self.call_index = 0
        self.messages_received: List[List[Dict]] = []

    async def complete_with_tools(
        self,
        messages: List[Dict[str, Any]],
        tools: List[Dict[str, Any]] = None,
        **kwargs,
    ) -> CompletionResponse:
        """Return next response in sequence."""
        self.messages_received.append(messages)

        if self.call_index >= len(self.responses):
            # Default: return stop response
            return create_mock_llm_response(content="Task completed.")

        response = self.responses[self.call_index]
        self.call_index += 1
        return response


# =============================================================================
# Capability: File Search
# =============================================================================


@pytest.mark.capability("code_search")
class TestFileSearchCapability:
    """Test Code Agent's file search capabilities."""

    @pytest.mark.asyncio
    async def test_glob_search_invocation(self):
        """Test that agent correctly invokes Glob tool for file search."""
        # Mock LLM: first call returns Glob tool call, second returns result
        mock_responses = [
            create_mock_llm_response(tool_calls=[
                {"name": "Glob", "arguments": {"pattern": "**/*.py"}}
            ]),
            create_mock_llm_response(content="Found 5 Python files:\n- main.py\n- utils.py"),
        ]
        mock_llm = MockLLMForCodeAgent(mock_responses)

        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.vcpu.llm = mock_llm

            # Mock spawn/wait to simulate kernel execution
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 0,
                "result": {"text": "Found 5 Python files"},
                "token_usage": 500,
            })

            result = await agent.run(
                goal="Find all Python files",
                allowed_tools={"Glob"},
            )

            assert result["status"] == "success"

    @pytest.mark.asyncio
    async def test_grep_search_invocation(self):
        """Test that agent correctly invokes Grep tool for content search."""
        mock_responses = [
            create_mock_llm_response(tool_calls=[
                {"name": "Grep", "arguments": {"pattern": "def main", "type": "py"}}
            ]),
            create_mock_llm_response(content="Found 'def main' in 3 files"),
        ]
        mock_llm = MockLLMForCodeAgent(mock_responses)

        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.vcpu.llm = mock_llm
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 0,
                "result": {"text": "Found def main in 3 files"},
            })

            result = await agent.run(
                goal="Find 'def main' in Python files",
                allowed_tools={"Grep"},
            )

            assert result["status"] == "success"


# =============================================================================
# Capability: File Reading
# =============================================================================


@pytest.mark.capability("code_understanding")
class TestFileReadCapability:
    """Test Code Agent's file reading capabilities."""

    @pytest.mark.asyncio
    async def test_read_file_invocation(self):
        """Test that agent correctly invokes Read tool."""
        mock_responses = [
            create_mock_llm_response(tool_calls=[
                {"name": "Read", "arguments": {"file_path": "src/main.py"}}
            ]),
            create_mock_llm_response(content="The main.py file contains the entry point..."),
        ]
        mock_llm = MockLLMForCodeAgent(mock_responses)

        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.vcpu.llm = mock_llm
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 0,
                "result": {"text": "File contains entry point"},
            })

            result = await agent.run(
                goal="Read and explain src/main.py",
                allowed_tools={"Read"},
            )

            assert result["status"] == "success"

    @pytest.mark.asyncio
    async def test_read_multiple_files(self):
        """Test reading multiple files in sequence."""
        mock_responses = [
            create_mock_llm_response(tool_calls=[
                {"name": "Read", "arguments": {"file_path": "file1.py"}},
                {"name": "Read", "arguments": {"file_path": "file2.py"}},
            ]),
            create_mock_llm_response(content="Both files implement..."),
        ]

        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 0,
                "result": {"text": "Compared both files"},
            })

            result = await agent.run(
                goal="Compare file1.py and file2.py",
                allowed_tools={"Read"},
            )

            assert result["status"] == "success"


# =============================================================================
# Capability: Multi-Tool Orchestration
# =============================================================================


@pytest.mark.capability("task_decomposition")
class TestMultiToolOrchestration:
    """Test Code Agent's ability to orchestrate multiple tools."""

    @pytest.mark.asyncio
    async def test_search_then_read(self):
        """Test Glob -> Read workflow."""
        # Agent should: 1) Glob to find files, 2) Read to examine content
        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 0,
                "result": {"text": "Found and analyzed 3 Python files"},
                "turns": 3,  # Multiple turns for multi-step
            })

            result = await agent.run(
                goal="Find all test files and show their imports",
                allowed_tools={"Glob", "Read"},
            )

            assert result["status"] == "success"
            assert "turns" in result

    @pytest.mark.asyncio
    async def test_grep_then_read(self):
        """Test Grep -> Read workflow."""
        with patch('nimbus.apps.code_agent.create_llm_client') as mock_create:
            mock_create.return_value = MagicMock()

            agent = CodeAgent()
            agent.kernel.spawn = AsyncMock(return_value="pid")
            agent.kernel.wait = AsyncMock(return_value={
                "exit_code": 0,
                "result": {"text": "Found pattern and analyzed context"},
                "turns": 2,
            })

            result = await agent.run(
                goal="Find 'TODO' comments and explain what needs to be done",
                allowed_tools={"Grep", "Read"},
            )

            assert result["status"] == "success"


