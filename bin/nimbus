#!/usr/bin/env python3
"""Nimbus CLI entry point script.

This script sets up the correct Python path and runs the Nimbus CLI.
"""

import os
import sys

# Add the parent directory (agent-framework) to the Python path
# so that 'nimbus' package can be imported
script_dir = os.path.dirname(os.path.abspath(__file__))
nimbus_dir = os.path.dirname(script_dir)  # /path/to/nimbus
agent_framework_dir = os.path.dirname(nimbus_dir)  # /path/to/agent-framework

if agent_framework_dir not in sys.path:
    sys.path.insert(0, agent_framework_dir)

from nimbus.cli.main import cli

if __name__ == "__main__":
    cli()
